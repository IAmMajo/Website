---
import { Image } from "astro:assets";
import { Card } from "m3-svelte";
import CvTabs from "../components/CvTabs.svelte";
import Button from "../components/Button.astro";
import GithubButton from "../components/GithubButton.astro";
import Icon from "../components/Icon.astro";
import Timeline from "../components/Timeline.astro";
import TimelineItem from "../components/TimelineItem.astro";
import applicationPhoto from "../images/application-photo.jpg";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mein Lebenslauf">
  <div class="cv gap-16">
    <div class="gap-8">
      <div class="introduction gap-8">
        <Card variant="elevated">
          <div class="fact-sheet-content gap-16">
            <div class="application-photo">
              <Image
                src={applicationPhoto}
                width={205}
                densities={[1, 2, 3, 4]}
                format="avif"
                quality="high"
                priority
                alt="Bewerbungsfoto"
              />
            </div>
            <div class="facts gap-8">
              <h1 class="display-small">Max Overlack</h1>
              <div class="gap-5">
                <div class="fact">
                  <Icon name="home" />
                  {/* Musterstr. 100, 12345 */} Duisburg
                </div>
                <div class="fact">
                  <Icon name="event" />
                  <time datetime="2001-02-27">27.02.2001</time>
                </div>
                <div class="fact">
                  <Icon name="cake" /> Berlin
                </div>
              </div>
            </div>
          </div>
        </Card>
        <Card variant="elevated">
          <div class="profile gap-16">
            <div class="gap-8">
              <h2 class="headline">Profil</h2>
              <div class="gap-16">
                <p>
                  Als Student der Medieninformatik mit abgeschlossener
                  Ausbildung zum Fachinformatiker für Anwendungsentwicklung
                  verbinde ich fundiertes theoretisches Wissen mit mehr als
                  sechs Jahren praktischer Erfahrung in der Web- und
                  Softwareentwicklung. Durch meine parallele Tätigkeit als
                  Werkstudent in der Backend- und Frontend-Entwicklung arbeite
                  ich kontinuierlich an realen, produktiven Systemen und
                  übernehme Verantwortung für performante und nachhaltige
                  Lösungen.
                </p>
                <p>
                  Mein technisches Fundament reicht von skalierbarer
                  PHP-Entwicklung mit Symfony-basierten Systemen bis hin zu
                  modernen JavaScript- und TypeScript-Stacks im Frontend und
                  Backend.
                </p>
                <p>
                  Ich strebe eine langfristige Tätigkeit in der Web- und
                  Softwareentwicklung an, in der ich anspruchsvolle technische
                  Herausforderungen mit analytischem Denken, Kreativität und
                  hoher Lösungsorientierung verbinde.
                </p>
              </div>
            </div>
            <div class="buttons gap-8">
              {
                /*
                <Button
                  variant="text"
                  href="tel:+4912341234567"
                  icon="call"
                  printText="+49 1234 1234567"
                  target="_blank"
                />
                */
              }
              {
                /*
                <Button
                  variant="text"
                  href="mailto:example@example.com"
                  icon="mail"
                  target="_blank"
                />
                */
              }
              <GithubButton path="IAmMajo" />
            </div>
          </div>
        </Card>
      </div>
      <div class="highlight">
        <Card variant="filled">
          <div class="projects body-large">
            <p>Sie interessieren sich für meine Projekte?</p>
            <Button
              variant="tonal"
              href="https://maxoverlack.dev/projekte/"
              icon="attractions"
              text="Meine Projekte"
            />
          </div>
        </Card>
      </div>
    </div>
    <Timeline headline="Berufserfahrung">
      <TimelineItem
        title="Full-Stack-Entwickler"
        entity="FoxBase GmbH"
        startDate="2025-03"
      >
        <ul class="gap-4">
          <li>Erst im Rahmen meines Praxissemesters, danach als Werkstudent</li>
          <li>Hauptsächlich TS-Entwicklung im Backend mit Express</li>
          <li>Auch TS-Entwicklung im Frontend mit Angular und Vue</li>
          <li>
            Beteiligung an der Entwicklung des FoxBase KI-Produkt-Experten
          </li>
        </ul>
      </TimelineItem>
      <TimelineItem
        title="Full-Stack-Entwickler"
        entity="Krankikom GmbH"
        startDate="2022-07"
        endDate="2025-02"
      >
        <ul class="gap-4">
          <li>Neben dem Studium als Werkstudent</li>
          <li>
            Hauptsächlich PHP-Entwicklung mit Pimcore (basierend auf Symfony),
            aber auch JS-Entwicklung
          </li>
          <li>
            Kontinuierliche Weiterentwicklung einer Website mit mehr als 400 000
            monatlich aktiven Nutzer*innen
          </li>
          <li>
            Implementierung von Such-, Sortier- und Filtermöglichkeiten für
            mehrere Websites mit Elasticsearch
          </li>
          <li>
            Durchführung von CMS/DXP-Schulungen für mehrere Kundenunternehmen
          </li>
        </ul>
      </TimelineItem>
    </Timeline>
    <Timeline headline="Bildung">
      <TimelineItem
        title="Medieninformatik B.Sc."
        entity="Hochschule Rhein-Waal"
        startDate="2022-09"
      >
        <ul class="gap-4">
          <li>Aktueller Schnitt: 1,8</li>
          <li>
            Durchführung von Projekten in den Bereichen Web-, Spiele- und
            App-Entwicklung
          </li>
          <li>Entwicklung mit Java, JS/TS, C#, Dart, Kotlin und Swift</li>
          <li>
            Verwendung von Angular, React, Vue/Nuxt, Astro, Swift Vapor, Unity,
            Flutter und Jetpack Compose
          </li>
          <li>
            Vorraussichtlicher Abschluss im <time datetime="2026-05">
              Mai 2026
            </time>
          </li>
        </ul>
      </TimelineItem>
      <TimelineItem
        title="Fachinformatiker Anwendungsentwicklung"
        startDate="2019-08"
        endDate="2022-06"
      >
        <div class="gap-4">
          <h2 class="title-small">Betrieb (Krankikom GmbH)</h2>
          <ul class="gap-4">
            <li>IHK-Note: 2,1</li>
            <li>Lernen von HTML, CSS und JS</li>
            <li>
              Hauptsächlich PHP-Entwicklung mit Pimcore (basierend auf Symfony)
            </li>
            <li>Auch TS-Entwicklung mit Ionic und Angular</li>
            <li>
              Beteiligung an der Entwicklung von Websites für kleine und große
              Unternehmen
            </li>
          </ul>
        </div>
        <div class="gap-4">
          <h2 class="title-small">
            Berufsschulen (Bertolt-Brecht-Berufskolleg und Kaufmännisches
            Berufskolleg Duisburg-Mitte)
          </h2>
          <ul class="gap-4">
            <li>Schnitt: 1,2</li>
            <li>Entwicklung mit C++ und Java</li>
          </ul>
        </div>
      </TimelineItem>
      <TimelineItem
        title="Abitur"
        entity="Gymnasium Rheinkamp Europaschule Moers"
        startDate="2011-09"
        endDate="2019-07"
      >
        <ul class="gap-4">
          <li>Schnitt: 2,4</li>
          <li>
            Abiturfächer: Mathematik (LK), Englisch (LK), Geschichte und
            Informatik
          </li>
          <li>
            Entwicklung mit Java im Informatik-Unterricht und in der Freizeit
          </li>
          <li>
            Bilinguales Abitur / Unterricht teilweise auf Englisch /
            C1-Englischkenntnisse
          </li>
        </ul>
      </TimelineItem>
    </Timeline>
    <CvTabs client:only="svelte" class="screen" />
    <CvTabs class="print" />
    <CvTabs class="print" tab="additional-qualifications" />
  </div>
</Layout>
<style>
  h1,
  h2,
  h4,
  ul {
    margin: 0;
  }
  .gap-4 {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .gap-5 {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .gap-8 {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .gap-16 {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .cv {
    padding: 16px 0;
    max-width: 840px;
    margin: auto;
  }
  .introduction {
    margin: 0 16px;
  }
  .fact-sheet {
    flex-flow: row wrap;
    align-items: center;
  }
  .application-photo {
    display: flex;
    justify-content: center;
    flex: 1;
  }
  img {
    border-radius: var(--m3-shape-medium);
  }
  .facts {
    flex: 1;
    min-width: 205px;
  }
  .fact {
    display: flex;
    gap: 1ch;
    align-items: center;
  }
  .buttons {
    justify-content: center;
    flex-flow: row wrap;
  }
  .buttons :global(.m3-container) {
    width: 223px;
  }
  .highlight {
    margin: 0 16px;
  }
  .projects {
    text-align: center;
    display: flex;
    flex-wrap: wrap;
    gap: 16px 1ch;
    justify-content: center;
    align-items: center;
  }
  ul {
    padding-left: 16px;
  }
  @media (min-width: 532px) {
    .introduction {
      flex-direction: row;
    }
    .fact-sheet {
      flex-flow: column;
    }
    .application-photo {
      flex: unset;
    }
    .profile {
      height: 100%;
      justify-content: space-between;
    }
  }
  @media (min-width: 600px) {
    .cv {
      padding: 24px;
    }
    .introduction {
      margin: unset;
    }
    .highlight {
      margin: unset;
    }
  }
</style>
