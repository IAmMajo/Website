---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { Card } from "m3-svelte";

interface Props {
  title: string;
  username: string;
  href: string;
  logoTitle?: string;
  inSubcategory?: boolean;
  invert?: boolean;
}

const {
  title,
  username,
  href,
  logoTitle = title,
  inSubcategory,
  invert,
} = Astro.props;

const Heading = inSubcategory ? "h4" : "h3";
const images = import.meta.glob<{ default: ImageMetadata }>(
  "../images/logos/**/*",
);
const logoTitleNoSpaces = logoTitle.replaceAll(" ", "-");
const imageName = logoTitleNoSpaces.toLowerCase().replaceAll(".", "");
const imagePath = `../images/logos/${imageName}`;
const darkImagePath = `../images/logos/dark/${imageName}`;
let format = "svg";
let image = images[`${imagePath}.svg`];
let darkImage = images[`${darkImagePath}.svg`];
const densities = [];
if (!image) {
  format = "png";
  image = images[`${imagePath}.png`];
  darkImage = images[`${darkImagePath}.png`];
  if (!image) {
    throw new Error(`Image ${imageName} not found`);
  }
  const imageWidth = (await image()).default.width;
  if (imageWidth > 184) {
    densities.push(1, 2);
    if (imageWidth > 276) {
      densities.push(3);
    }
  }
}
const alt = `${logoTitleNoSpaces}-Logo`;
---

<a {href} target="_blank" class="account">
  <!-- @ts-expect-error Expression produces a union type that is too complex to represent -->
  <Card client:load variant="elevated" onclick>
    <section>
      <div class="img-wrapper">
        <Image
          class:list={[{ invert: invert, light: darkImage }]}
          src={image()}
          width={92}
          height={92}
          fit="contain"
          {densities}
          {format}
          {alt}
        />
        {
          darkImage && (
            <Image
              class="dark"
              src={darkImage()}
              width={92}
              height={92}
              fit="contain"
              {densities}
              {format}
              {alt}
            />
          )
        }
      </div>
      <Heading class="title">{title}</Heading>
      <div class="username">{username}</div>
    </section>
  </Card>
</a>
<style>
  .account {
    margin: 4px;
    width: calc(100% - 8px);
    text-decoration: none;
  }
  .account :global(.m3-container) {
    width: 100%;
  }
  .title {
    margin: 0;
  }
  .img-wrapper {
    position: relative;
    margin: calc((50% - 32px) / 3) auto calc((50% + 16px) / 3);
    padding-top: calc((200% + 64px) / 3);
    width: calc((200% + 64px) / 3);
  }
  img {
    position: absolute;
    height: 100%;
    width: 100%;
    top: 0;
    object-fit: contain;
  }
  .username {
    color: var(--m3c-on-surface-variant);
  }

  @media (min-width: 320px) {
    .account {
      width: calc(50% - 8px);
    }
  }
  @media (min-width: 468px) {
    .account {
      width: calc(100% / 3 - 8px);
    }
  }
  @media (min-width: 616px) {
    .account {
      width: calc(25% - 8px);
    }
  }
  @media (min-width: 860px) {
    .account {
      width: calc(20% - 8px);
    }
  }
</style>
