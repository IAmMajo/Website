---
import { Button } from "m3-svelte";
import githubLogo from "../images/logos/github.svg?raw";

interface Props {
  path: string;
  urlPath?: string;
}

const { path, urlPath = path } = Astro.props;
---

<!-- @ts-expect-error Expression produces a union type that is too complex to represent -->
<Button
  client:load
  variant="text"
  href={`https://github.com/${urlPath}`}
  target="_blank"
>
  <span set:html={githubLogo} />
  github.com/{path}
</Button>
<style>
  span,
  span :global(svg) {
    width: 24px;
    height: 24px;
  }
  span :global(path) {
    fill: currentColor;
  }
</style>
